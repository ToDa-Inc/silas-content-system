# Supabase (service role for API + worker — bypasses RLS)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Default org created by migrate.py (slug)
DEFAULT_ORG_SLUG=silas-agency

# Apify + OpenRouter (worker jobs)
APIFY_API_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# API server
CORS_ORIGINS=http://localhost:3000
