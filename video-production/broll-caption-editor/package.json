{
  "name": "broll-caption-editor",
  "version": "1.0.0",
  "description": "Remotion-based B-roll caption editor for Instagram Reels",
  "type": "module",
  "scripts": {
    "dev": "remotion studio src/Root.jsx",
    "dev:card": "remotion studio src/RootCardCaptionsOnly.jsx",
    "build": "remotion render src/Root.jsx --output-path=./out/video.mp4",
    "build:captions": "remotion render src/RootCaptionsOnly.jsx --output-path=./out/captions-only.mp4",
    "build:card": "remotion render src/RootCardCaptionsOnly.jsx --output-path=./out/card-captions-only.mp4",
    "build:card:seq": "remotion render src/RootCardCaptionsOnly.jsx --output-path=./out/card-captions-only.mp4 --sequence"
  },
  "dependencies": {
    "@remotion/google-fonts": "^4.0.435",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^5.0.0"
  }
}
