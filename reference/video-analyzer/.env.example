# Video Analyzer Configuration Template
# Copy this file to your config/.env and fill in your values

# ===========================================
# REQUIRED API KEYS
# ===========================================

# Apify API Token
# Get from: https://console.apify.com/
# 1. Go to Settings → API & Integrations → API Tokens
# 2. Copy your default token
# Example: apify_api_xxxxxxxxxxxxxxxxxxxx
APIFY_API_TOKEN=your_apify_token_here

# OpenAI API Key (for Whisper transcription)
# Get from: https://platform.openai.com/api-keys
# Note: Must be full key (starts with sk-proj-), not OpenRouter
# Example: sk-proj-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=your_openai_key_here

# OpenRouter API Key (for Vision analysis)
# Get from: https://openrouter.ai/keys
# Example: sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=your_openrouter_key_here

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================

# Default number of reels to analyze
DEFAULT_LIMIT=10

# Default video type (auto, talking-head, text-overlay)
DEFAULT_TYPE=auto

# Include transcript by default (true/false)
DEFAULT_FULL=false

# ===========================================
# COSTS (for reference)
# ===========================================
# Apify scraping: $0.0026 per reel
# Whisper transcription: $0.006 per minute
# Haiku Vision: $0.0004 per frame
# 
# Estimated cost per full analysis:
# - Text overlay video: ~$0.01
# - Talking head (60s): ~$0.04
# - Full analysis with transcript: ~$0.05
